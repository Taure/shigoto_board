{erl_opts, [debug_info, warnings_as_errors]}.

{deps, [
    {nova, {git, "https://github.com/novaframework/nova.git", {branch, "main"}}},
    {arizona_core, {git, "https://github.com/arizona-framework/arizona_core.git", {branch, "main"}}},
    {arizona_nova, {git, "https://github.com/arizona-framework/arizona_nova.git", {branch, "main"}}},
    {shigoto, {git, "https://github.com/Taure/shigoto.git", {branch, "main"}}}
]}.

{project_plugins, [
    erlfmt,
    rebar3_ex_doc,
    {rebar3_audit, {git, "https://github.com/Taure/rebar3_audit.git", {branch, "main"}}},
    {rebar3_sbom,
        {git, "https://github.com/Taure/rebar3_sbom.git", {branch, "feat/include-otp-components"}}}
]}.

{erlfmt, [write]}.

{ex_doc, [
    {proglang, erlang},
    {main, <<"readme">>},
    {extras, [<<"README.md">>]},
    {source_url, <<"https://github.com/Taure/shigoto_board">>}
]}.
